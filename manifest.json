{
    "id": "/",

    "name": "APP SICUR. UNICO",
    "short_name": "APP SICUR.",
    "description": "Gestione del personale FIG Sicur UniCo: città, gruppi e incarichi con supporto offline.",

    "lang": "it",
    "dir": "ltr",

    "start_url": "/index.html?source=pwa",
    "scope": "/",

    "display": "fullscreen",
    "display_override": ["standalone", "fullscreen", "minimal-ui"],
    "orientation": "portrait",

    "background_color": "#066731",
    "theme_color": "#066731",

    "icons": [
        {
            "src": "/assets/icons/icon-96.png",
